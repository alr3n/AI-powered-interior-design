rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(ownerId) { return signedIn() && request.auth.uid == ownerId; }
    function ownsProject(projectId) {
      return signedIn() &&
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    match /users/{uid} {
      allow read, delete: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid;
      // aiUsage is written by Cloud Functions (admin SDK bypasses rules);
      // block clients from resetting their own quota. This must be the ONLY
      // allow-update rule in this match block — multiple allow statements for
      // the same operation are OR'd, so a second unconditional update rule
      // would silently defeat this check.
      allow update: if signedIn() && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['aiUsage']);
    }

    match /projects/{projectId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);

      match /{sub}/{docId} {
        // rooms, analyses, designs, costEstimates, chats
        allow read, write: if ownsProject(projectId);
      }
    }

    match /designTips/{tipId} { allow read: if true; allow write: if false; }
    match /costCatalog/{region} { allow read: if true; allow write: if false; }
    match /aiCache/{key} { allow read, write: if false; } // server only
  }
}
